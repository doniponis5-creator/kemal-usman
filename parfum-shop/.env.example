# ─── PUBLIC (shipped to client bundle — VITE_*) ────────────────────────────────
# Public PocketBase URL — MUST be HTTPS in production.
# Local dev can be http://127.0.0.1:8090
VITE_PB_URL=https://api.kemalusman.kg

# Public app URL (used by share / referral links, deep links)
VITE_APP_URL=https://kemalusman.kg

# Public Sentry DSN (optional — leave empty to disable)
VITE_SENTRY_DSN=

# ─── SERVER-SIDE ONLY (never prefixed VITE_ — used by deploy scripts) ──────────
# PocketBase admin email + password — used ONLY by pb-secure-rules.js + migrations.
# ROTATE the value below before first run. Never commit the real value.
PB_ADMIN_EMAIL=admin@kemalusman.kg
PB_ADMIN_PASSWORD=CHANGE_ME_BEFORE_RUNNING

# WhatsApp Green API — server-side only, called from PocketBase hooks
GREEN_API_INSTANCE=
GREEN_API_TOKEN=
WHATSAPP_ADMIN_PHONE=996557100505

# Domain for Caddy / Let's Encrypt
PUBLIC_DOMAIN=api.kemalusman.kg
ACME_EMAIL=admin@kemalusman.kg

# SMS OTP provider (SMSC.kg, Nikita Mobile, etc.)
SMS_PROVIDER=smsc
SMS_API_LOGIN=
SMS_API_PASSWORD=
SMS_SENDER=KemalUsman
